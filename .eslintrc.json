{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "script"
  },
  "plugins": ["html"],
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "no-empty": "warn"
  }
}
